# ==============================================================================
# Environment Variables — Local Development
# ==============================================================================
# Copy to .env and customise as needed.
# All variables are prefixed with AML_ to avoid collisions.
# ==============================================================================

# --- Application ---
AML_DEBUG=true
AML_ENVIRONMENT=development
AML_LOG_LEVEL=DEBUG
AML_LOG_FORMAT=console

# --- Database ---
AML_DATABASE_URL=postgresql+asyncpg://aml:aml@localhost:5432/aml

# --- Redis ---
AML_REDIS_URL=redis://localhost:6379/0

# --- AI / LLM ---
# Options: bedrock | ollama | mock
AML_LLM_PROVIDER=mock
# AML_BEDROCK_REGION=us-east-1
# AML_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# AML_OLLAMA_BASE_URL=http://localhost:11434
# AML_OLLAMA_MODEL=llama3.2

# --- Vector Database ---
AML_VECTOR_DB_PROVIDER=milvus
AML_MILVUS_HOST=localhost
AML_MILVUS_PORT=19530
