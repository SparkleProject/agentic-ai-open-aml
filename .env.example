# ==============================================================================
# Environment Variables — Local Development
# ==============================================================================
# Copy to .env and customise as needed.
# All variables are prefixed with AML_ to avoid collisions.
# ==============================================================================

# --- Application ---
AML_DEBUG=true
AML_ENVIRONMENT=development
AML_LOG_LEVEL=DEBUG
AML_LOG_FORMAT=console

# --- Database ---
AML_DATABASE_URL=postgresql+asyncpg://aml:aml@localhost:5432/aml

# --- Redis ---
AML_REDIS_URL=redis://localhost:6379/0

# --- AI / LLM (Chat) ---
# Options: azure | bedrock | ollama | mock
AML_LLM_PROVIDER=azure
# AML_AZURE_OPENAI_API_KEY=your-api-key
# AML_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AML_AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.1
# AML_AZURE_OPENAI_REASONING_EFFORT=low
# AML_BEDROCK_REGION=us-east-1
# AML_OLLAMA_BASE_URL=http://localhost:11434

# --- Embedding ---
# Options: ollama | bedrock | mock
AML_EMBEDDING_PROVIDER=ollama
AML_EMBEDDING_DIMENSIONS=1024
AML_OLLAMA_EMBEDDING_MODEL=mxbai-embed-large

# --- Vector Database ---
AML_VECTOR_DB_PROVIDER=milvus
AML_MILVUS_HOST=localhost
AML_MILVUS_PORT=19530
